# Full image already ships with gcc / build-essential — no apt-get needed
FROM python:3.12-slim

# ==== Environment ====
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# ==== Python dependencies ====
COPY requirements.txt .
RUN pip install --upgrade pip && \
    pip install -r requirements.txt

# ==== Download CAMeL Tools models ====
RUN camel_data -i light

# ==== Download NLTK data ====
RUN python -c "import nltk; \
    [nltk.download(p, quiet=True) for p in [ \
        'stopwords', 'wordnet', 'punkt', 'punkt_tab', \
        'averaged_perceptron_tagger', \
        'averaged_perceptron_tagger_eng', \
        'omw-1.4' \
    ]]"

# ==== Application code ====
COPY . .

RUN mkdir -p logs models/english models/arabic

EXPOSE 5000

# Pure-Python healthcheck — no curl required
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:5000/api/health')" || exit 1

CMD ["python", "app.py"]